{
  "name": "visualg-web",
  "productName": "VisuAlg Web",
  "version": "0.2.0",
  "description": "IDE web e desktop para pseudocodigo no estilo VisuAlg 3.0.7",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "dev:web": "vite --config vite.renderer.config.mjs",
    "build:web": "vite build --config vite.renderer.config.mjs",
    "preview:web": "vite preview --config vite.renderer.config.mjs",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint src/js electron e2e playwright.config.mjs eslint.config.mjs",
    "test:e2e": "npm run build:web && playwright test",
    "test:e2e:chromium": "npm run build:web && playwright test --project=chromium",
    "test:examples": "node scripts/examples-check.js",
    "test:workspace": "node scripts/workspace-recovery-check.js",
    "test:standard": "node scripts/standard-program-check.js",
    "test:compat": "node scripts/compatibility-check.js",
    "test:security": "node scripts/electron-security-check.mjs",
    "test:p0": "node scripts/regression-check.js && npm run test:standard && npm run test:compat && npm run test:examples && npm run test:workspace && npm run test:security",
    "test:ci": "npm run lint && npm run test:p0 && npm run build:web"
  },
  "keywords": [],
  "author": {
    "name": "VisuAlg Web contributors",
    "email": "contato@conradosal.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/Gregorio-A/visualg-web#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gregorio-A/visualg-web.git"
  },
  "bugs": {
    "url": "https://github.com/Gregorio-A/visualg-web/issues"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@playwright/test": "^1.61.1",
    "electron": "42.5.0",
    "eslint": "^9.39.5",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  }
}
